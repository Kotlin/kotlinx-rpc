{
  "mcpServers": {
    "youtrack": {
      "type": "http",
      "url": "https://youtrack.jetbrains.com/mcp",
      "headers": {
        "Authorization": "Bearer ${YOUTRACK_TOKEN}"
      }
    },
    "youtrack-agent": {
      "type": "http",
      "url": "https://youtrack.jetbrains.com/mcp",
      "headers": {
        "Authorization": "Bearer ${YOUTRACK_AGENT_TOKEN}"
      }
    },
    "gradle": {
      "command": "jbang",
      "args": [
        "run",
        "--quiet",
        "--fresh",
        "gradle-mcp@rnett"
      ]
    }
  }
}
