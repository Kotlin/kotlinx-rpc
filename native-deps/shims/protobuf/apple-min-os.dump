# Apple minimum OS (deployment target) pinning for the native-deps Bazel builds (KRPC-609).
#
# GENERATED — do NOT edit by hand: run the 'generateAppleMinOsDump' Gradle task (on macOS) and commit.
# Each value is max(Kotlin/Native 2.3.0 osVersionMin, the architecture's real floor).
# The arch floor only dominates for true-arm64 watchOS device, which exists solely on watchOS 26+,
# so its minimum is 26.x even though Kotlin/Native nominally lists 9.0. Imported by .bazelrc to pin
# --<platform>_minimum_os, and checked object-by-object by the 'appleMinOsTest' verification.

build:macos_arm64 --macos_minimum_os=11.0
build:ios_arm64 --ios_minimum_os=14.0
build:ios_simulator_arm64 --ios_minimum_os=14.0
build:ios_x64 --ios_minimum_os=14.0
build:tvos_arm64 --tvos_minimum_os=14.0
build:tvos_simulator_arm64 --tvos_minimum_os=14.0
build:watchos_arm32 --watchos_minimum_os=7.0
build:watchos_arm64 --watchos_minimum_os=7.0
build:watchos_device_arm64 --watchos_minimum_os=26.0
build:watchos_simulator_arm64 --watchos_minimum_os=7.0
